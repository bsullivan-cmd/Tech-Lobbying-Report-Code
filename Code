function onOpen() {
SpreadsheetApp.getUi()
  .createMenu("LDA Tools")
  .addItem("Full Rebuild (wipes + refetches everything)", "runAll")
  .addItem("Check For New Filings Now", "refreshNewFilings")
  .addSeparator()
  .addItem("Enable Auto-Refresh (every 5 min)", "enableAutoRefresh")
  .addItem("Disable Auto-Refresh", "disableAutoRefresh")
  .addToUi();
}
