// ============================================================
//  MAIN ENTRY POINT
// ============================================================
function runAll() {
  setupSheet();
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("LDA Q2 2025");
  let rowIndex = 2;

  for (const company of TARGET_COMPANIES) {
    Logger.log(`\n===== Processing: ${company.label} =====`);
    const rows = fetchAllVariations(company);

    if (rows.length === 0) {
      sheet.getRange(rowIndex, 1, 1, 8).setValues([[
        company.label, "—", "No filings found for Q2 2025", "—", "—", "—", "—", "—"
      ]]);

      // Light red background for no-result rows
      sheet.getRange(rowIndex, 1, 1, 8).setBackground("#fde8e8");
      rowIndex++;
    } else {
      // Color-code alternating companies for readability
      const bgColor = TARGET_COMPANIES.indexOf(company) % 2 === 0 ? "#f0f4ff" : "#ffffff";

      rows.forEach(row => {
        sheet.getRange(rowIndex, 1, 1, 8).setValues([row]);
        sheet.getRange(rowIndex, 1, 1, 8).setBackground(bgColor);

        // Highlight IN-HOUSE rows in green
        if (row[3] === "IN-HOUSE") {
          sheet.getRange(rowIndex, 4, 1, 1).setBackground("#d4edda").setFontColor("#155724");
        } else if (row[3] === "OUTSIDE FIRM") {
          sheet.getRange(rowIndex, 4, 1, 1).setBackground("#fff3cd").setFontColor("#856404");
        }

        rowIndex++;
      });
    }

    // Blank separator row between companies
    rowIndex++;
    Utilities.sleep(300);
  }

  // Auto-resize all columns
  for (let i = 1; i <= 8; i++) {
    sheet.autoResizeColumn(i);
  }

  Logger.log("All done!");
  SpreadsheetApp.getUi().alert("✅ LDA Q2 2025 data loaded!\n\nGreen = In-House | Yellow = Outside Firm | Red = No filings found");
}


// ============================================================
//  FETCH ACROSS ALL NAME VARIATIONS FOR ONE COMPANY
// ============================================================
function fetchAllVariations(company) {
  const allRows = [];
  const seenFilings = new Set();

  for (const name of company.names) {
    // Search as client (company hired a lobbying firm)
    const clientFilings = searchFilings(name, "client");
    // Search as registrant (company has in-house lobbyists)
    const registrantFilings = searchFilings(name, "registrant");
    const combined = [...clientFilings, ...registrantFilings];

    for (const filing of combined) {
      if (seenFilings.has(filing.filing_uuid)) continue;
      seenFilings.add(filing.filing_uuid);

      const rows = buildRows(company.label, filing);
      allRows.push(...rows);
    }

    Utilities.sleep(200);
  }

  return allRows;
}


// ============================================================
//  SEARCH FILINGS BY CLIENT OR REGISTRANT NAME
// ============================================================
function searchFilings(name, role) {
  const allResults = [];
  const paramKey = role === "client" ? "client_name" : "registrant_name";
  let page = 1;
  let hasMore = true;

  while (hasMore) {
    const url = `${BASE_URL}/filings/?${paramKey}=${encodeURIComponent(name)}&filing_year=${FILING_YEAR}&filing_period=${FILING_PERIOD}&page=${page}&page_size=25&format=json`;

    try {
      const response = UrlFetchApp.fetch(url, {
        headers: { "Authorization": "Token " + API_KEY },
        muteHttpExceptions: true
      });

      const code = response.getResponseCode();
      if (code === 401) {
        throw new Error("Invalid API key — check your key at lda.gov");
      }
      if (code !== 200) {
        Logger.log(`HTTP ${code} for "${name}" (${role}), page ${page}`);
        break;
      }

      const data = JSON.parse(response.getContentText());
      if (data.results && data.results.length > 0) {
        const filtered = data.results.filter(filing => {
          const filingType = (filing.filing_type_display || "").toLowerCase();
          const registrant = (filing.registrant?.name || "").toLowerCase();
          const isAmendmentOrReg = filingType.includes("amendment") || filingType.includes("registration");
          const hasMetal = registrant.includes("metal");
          return !isAmendmentOrReg && !hasMetal;
        });
        allResults.push(...filtered);
        Logger.log(`  Found ${filtered.length} filing(s) for "${name}" as ${role} (after filters)`);
      }

      hasMore = !!data.next;
      page++;
      Utilities.sleep(150);

    } catch (e) {
      Logger.log(`Error for "${name}" (${role}): ${e}`);
      break;
    }
  }

  return allResults;
}


// ============================================================
//  BUILD SHEET ROWS FROM A FILING
// ============================================================
function buildRows(companyLabel, filing) {
  const rows = [];
  const clientName   = filing.client?.name || "—";
  const registrantName = filing.registrant?.name || "—";
  const filingType   = filing.filing_type_display || "—";
  const filingDate   = filing.dt_posted ? filing.dt_posted.split("T")[0] : "—";
  const amount       = filing.income
    ? `$${Number(filing.income).toLocaleString()}`
    : filing.expenses
    ? `$${Number(filing.expenses).toLocaleString()}`
    : "—";

  // In-house = registrant name contains or matches the company's label keyword
  const keyword = companyLabel.split(" ")[0].toLowerCase();
  const isInHouse = registrantName.toLowerCase().includes(keyword) ||
                    clientName.toLowerCase().includes(registrantName.toLowerCase().split(" ")[0]);
  const firmType = isInHouse ? "IN-HOUSE" : "OUTSIDE FIRM";

  // Get individual lobbyist names from the filing detail
  const lobbyists = fetchLobbyistsForFiling(filing.filing_uuid);

  if (lobbyists.length === 0) {
    rows.push([companyLabel, clientName, registrantName, firmType, "No lobbyists listed", filingType, filingDate, amount]);
  } else {
    lobbyists.forEach(l => {
      const name = [
        l.lobbyist?.prefix || "",
        l.lobbyist?.first_name || "",
        l.lobbyist?.last_name || ""
      ].filter(Boolean).join(" ").trim() || "—";

      rows.push([companyLabel, clientName, registrantName, firmType, name, filingType, filingDate, amount]);
    });
  }

  return rows;
}


// ============================================================
//  FETCH INDIVIDUAL LOBBYISTS FROM A FILING DETAIL
// ============================================================
function fetchLobbyistsForFiling(filingUuid) {
  const url = `${BASE_URL}/filings/${filingUuid}/?format=json`;
  try {
    const response = UrlFetchApp.fetch(url, {
      headers: { "Authorization": "Token " + API_KEY },
      muteHttpExceptions: true
    });
    if (response.getResponseCode() !== 200) return [];
    const data = JSON.parse(response.getContentText());

    // Lobbyists can be nested inside lobbying_activities or at the top level
    if (data.lobbying_activities && data.lobbying_activities.length > 0) {
      return data.lobbying_activities.flatMap(a => a.lobbyists || []);
    }
    return data.lobbyists || [];
  } catch (e) {
    Logger.log(`Error fetching lobbyists for ${filingUuid}: ${e}`);
    return [];
  }
}


// ============================================================
//  SHEET SETUP WITH HEADERS + FORMATTING
// ============================================================
function setupSheet() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName("LDA Q2 2025");
  if (!sheet) {
    sheet = ss.insertSheet("LDA Q2 2025");
  } else {
    sheet.clearContents();
    sheet.clearFormats();
  }

  const headers = [
    "Target Company",
    "Client (as filed)",
    "Registrant / Firm",
    "In-House or Outside Firm",
    "Lobbyist Name",
    "Filing Type",
    "Filing Date",
    "Reported Amount"
  ];

  const headerRange = sheet.getRange(1, 1, 1, headers.length);
  headerRange.setValues([headers]);
  headerRange.setBackground("#1a1a2e");
  headerRange.setFontColor("#ffffff");
  headerRange.setFontWeight("bold");
  headerRange.setFontSize(11);
  headerRange.setFontFamily("Arial");
  sheet.setFrozenRows(1);

  return sheet;
}


