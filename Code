// ============================================================
//  NAME NORMALIZATION / MATCH VALIDATION
//  Replaces the old "contains 'metal'" hack. Requires a genuine
//  whole-word match instead of a loose substring match, which is
//  what let Metal (vs Meta) through — and would've let almost
//  anything through for a name as short as "X" or "Snap".
// ============================================================
function normalizeName(s) {
return (s || "")
  .toLowerCase()
  .replace(/[.,]/g, "")
  .replace(/\b(inc|llc|corp|corporation|ltd|pbc|co|holdings)\b/g, "")
  .replace(/\s+/g, " ")
  .trim();
}
function isGenuineMatch(targetName, candidateName) {
const a = normalizeName(targetName);
const b = normalizeName(candidateName);
if (!a || !b) return false;
if (a === b) return true;
const escaped = a.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
const re = new RegExp(`^${escaped}(\\s|$)`);
return re.test(b);
}
// True if candidateName genuinely matches ANY of this company's
// known name variations (used to validate API results and to
// detect in-house lobbying, replacing the old fragile keyword logic).
function matchesCompany(company, candidateName) {
return company.names.some(n => isGenuineMatch(n, candidateName));
}
// ============================================================
//  TRACKING SHEET (persists which filings we've already pulled in,
//  so a 5-min trigger can append only new data, not re-fetch)
// ============================================================
function getTrackingSheet() {
const ss = SpreadsheetApp.getActiveSpreadsheet();
let sheet = ss.getSheetByName(TRACKING_SHEET_NAME);
if (!sheet) {
  sheet = ss.insertSheet(TRACKING_SHEET_NAME);
  sheet.getRange(1, 1, 1, 2).setValues([["filing_uuid", "date_added"]]);
  sheet.hideSheet();
}
return sheet;
}
function loadSeenFilingIds() {
const sheet = getTrackingSheet();
const lastRow = sheet.getLastRow();
if (lastRow < 2) return new Set();
const ids = sheet.getRange(2, 1, lastRow - 1, 1).getValues().flat();
return new Set(ids);
}
function markFilingsSeen(uuids) {
if (!uuids || uuids.length === 0) return;
const sheet = getTrackingSheet();
const now = new Date();
const rows = uuids.map(id => [id, now]);
sheet.getRange(sheet.getLastRow() + 1, 1, rows.length, 2).setValues(rows);
}
function resetTracking() {
const sheet = getTrackingSheet();
sheet.clearContents();
sheet.getRange(1, 1, 1, 2).setValues([["filing_uuid", "date_added"]]);
}
// ============================================================
//  MAIN ENTRY POINTS
// ============================================================
// Full rebuild: wipes everything and refetches from scratch.
function runAll() {
setupSheet(true);
resetTracking();
const added = processCompanies({ incremental: false });
SpreadsheetApp.getUi().alert(
  `✅ Full rebuild complete!\n\n${added} filing row(s) loaded.\n\nGreen = In-House | Yellow = Outside Firm | Red = No filings found`
);
}
// Incremental refresh: appends only filings not already collected.
// Safe to run on a timer (e.g. every 5 minutes) — will not duplicate rows.
function refreshNewFilings() {
setupSheet(false);
const added = processCompanies({ incremental: true });
Logger.log(`Incremental refresh complete. ${added} new row(s) added.`);
}
// ============================================================
//  SHARED PROCESSING LOOP
// ============================================================
function processCompanies(opts) {
const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_NAME);
const seen = loadSeenFilingIds();
const newlySeenIds = [];
let rowIndex = Math.max(sheet.getLastRow() + 1, 2);
let addedCount = 0;
TARGET_COMPANIES.forEach((company, companyIdx) => {
  Logger.log(`\n===== Processing: ${company.label} =====`);
  const filings = fetchGenuineFilings(company);
  // Skip filings we've already recorded in a previous run
  const freshFilings = filings.filter(f => !seen.has(f.filing_uuid));
  if (freshFilings.length === 0) {
    if (!opts.incremental) {
      sheet.getRange(rowIndex, 1, 1, 9).setValues([[
        company.label, "—", "No filings found for this period", "—", "—", "—", "—", "—", new Date()
      ]]);
      sheet.getRange(rowIndex, 1, 1, 9).setBackground("#fde8e8");
      rowIndex++;
    }
  } else {
    const bgColor = companyIdx % 2 === 0 ? "#f0f4ff" : "#ffffff";
    freshFilings.forEach(filing => {
      const rows = buildRows(company, filing);
      rows.forEach(row => {
        sheet.getRange(rowIndex, 1, 1, 9).setValues([row]);
        sheet.getRange(rowIndex, 1, 1, 9).setBackground(bgColor);
        if (row[3] === "IN-HOUSE") {
          sheet.getRange(rowIndex, 4, 1, 1).setBackground("#d4edda").setFontColor("#155724");
        } else if (row[3] === "OUTSIDE FIRM") {
          sheet.getRange(rowIndex, 4, 1, 1).setBackground("#fff3cd").setFontColor("#856404");
        }
        rowIndex++;
        addedCount++;
      });
      newlySeenIds.push(filing.filing_uuid);
    });
  }
  if (!opts.incremental) rowIndex++; // blank separator row, full rebuild only
  Utilities.sleep(200);
});
markFilingsSeen(newlySeenIds);
for (let i = 1; i <= 9; i++) {
  sheet.autoResizeColumn(i);
}
return addedCount;
}
// ============================================================
//  FETCH + VALIDATE ACROSS ALL NAME VARIATIONS FOR ONE COMPANY
// ============================================================
function fetchGenuineFilings(company) {
const allRows = [];
const seenInThisFetch = new Set();
company.names.forEach(name => {
  const clientFilings = searchFilings(name, "client");
  const registrantFilings = searchFilings(name, "registrant");
  // Validate: the field we searched must genuinely match one of
  // this company's known names, not just contain the search text.
  const validClient = clientFilings.filter(f => matchesCompany(company, f.client?.name || ""));
  const validRegistrant = registrantFilings.filter(f => matchesCompany(company, f.registrant?.name || ""));
  [...validClient, ...validRegistrant].forEach(filing => {
    if (seenInThisFetch.has(filing.filing_uuid)) return;
    seenInThisFetch.add(filing.filing_uuid);
    allRows.push(filing);
  });
  Utilities.sleep(200);
});
return allRows;
}
// ============================================================
//  SEARCH FILINGS BY CLIENT OR REGISTRANT NAME
// ============================================================
function searchFilings(name, role) {
const allResults = [];
const paramKey = role === "client" ? "client_name" : "registrant_name";
let page = 1;
let hasMore = true;
while (hasMore) {
  const url = `${BASE_URL}/filings/?${paramKey}=${encodeURIComponent(name)}&filing_year=${FILING_YEAR}&filing_period=${FILING_PERIOD}&page=${page}&page_size=25&format=json`;
  try {
    const response = UrlFetchApp.fetch(url, {
      headers: { "Authorization": "Token " + API_KEY },
      muteHttpExceptions: true
    });
    const code = response.getResponseCode();
    if (code === 401) {
      throw new Error("Invalid API key — check your key at lda.gov");
    }
    if (code !== 200) {
      Logger.log(`HTTP ${code} for "${name}" (${role}), page ${page}`);
      break;
    }
    const data = JSON.parse(response.getContentText());
    if (data.results && data.results.length > 0) {
      // Only excludes amendments/registrations here — genuine
      // entity matching now happens in fetchGenuineFilings(),
      // not via a blacklist keyword.
      const filtered = data.results.filter(filing => {
        const filingType = (filing.filing_type_display || "").toLowerCase();
        return !filingType.includes("amendment") && !filingType.includes("registration");
      });
      allResults.push(...filtered);
      Logger.log(`  Found ${filtered.length} filing(s) for "${name}" as ${role}`);
    }
    hasMore = !!data.next;
    page++;
    Utilities.sleep(150);
  } catch (e) {
    Logger.log(`Error for "${name}" (${role}): ${e}`);
    break;
  }
}
return allResults;
}
// ============================================================
//  BUILD SHEET ROWS FROM A FILING
// ============================================================
function buildRows(company, filing) {
const rows = [];
const clientName = filing.client?.name || "—";
const registrantName = filing.registrant?.name || "—";
const filingType = filing.filing_type_display || "—";
const filingDate = filing.dt_posted ? filing.dt_posted.split("T")[0] : "—";
const amount = filing.income
  ? `$${Number(filing.income).toLocaleString()}`
  : filing.expenses
  ? `$${Number(filing.expenses).toLocaleString()}`
  : "—";
// In-house = the registrant genuinely IS the company itself
// (replaces the old fragile "first word of label" keyword check,
// which would've broken badly for a label like "X CORP (TWITTER)").
const isInHouse = matchesCompany(company, registrantName);
const firmType = isInHouse ? "IN-HOUSE" : "OUTSIDE FIRM";
const lobbyists = fetchLobbyistsForFiling(filing.filing_uuid);
if (lobbyists.length === 0) {
  rows.push([company.label, clientName, registrantName, firmType, "No lobbyists listed", filingType, filingDate, amount, new Date()]);
} else {
  lobbyists.forEach(l => {
    const name = [
      l.lobbyist?.prefix || "",
      l.lobbyist?.first_name || "",
      l.lobbyist?.last_name || ""
    ].filter(Boolean).join(" ").trim() || "—";
    rows.push([company.label, clientName, registrantName, firmType, name, filingType, filingDate, amount, new Date()]);
  });
}
return rows;
}
// ============================================================
//  FETCH INDIVIDUAL LOBBYISTS FROM A FILING DETAIL
// ============================================================
function fetchLobbyistsForFiling(filingUuid) {
const url = `${BASE_URL}/filings/${filingUuid}/?format=json`;
try {
  const response = UrlFetchApp.fetch(url, {
    headers: { "Authorization": "Token " + API_KEY },
    muteHttpExceptions: true
  });
  if (response.getResponseCode() !== 200) return [];
  const data = JSON.parse(response.getContentText());
  if (data.lobbying_activities && data.lobbying_activities.length > 0) {
    return data.lobbying_activities.flatMap(a => a.lobbyists || []);
  }
  return data.lobbyists || [];
} catch (e) {
  Logger.log(`Error fetching lobbyists for ${filingUuid}: ${e}`);
  return [];
}
}
// ============================================================
//  SHEET SETUP WITH HEADERS + FORMATTING
//  clearExisting=true wipes the sheet (full rebuild).
//  clearExisting=false just ensures the sheet/headers exist
//  (incremental refresh appends below existing rows).
// ============================================================
function setupSheet(clearExisting) {
const ss = SpreadsheetApp.getActiveSpreadsheet();
let sheet = ss.getSheetByName(SHEET_NAME);
const headers = [
  "Target Company",
  "Client (as filed)",
  "Registrant / Firm",
  "In-House or Outside Firm",
  "Lobbyist Name",
  "Filing Type",
  "Filing Date",
  "Reported Amount",
  "Added On"
];
if (!sheet) {
  sheet = ss.insertSheet(SHEET_NAME);
} else if (clearExisting) {
  sheet.clearContents();
  sheet.clearFormats();
}
if (sheet.getLastRow() === 0) {
  const headerRange = sheet.getRange(1, 1, 1, headers.length);
  headerRange.setValues([headers]);
  headerRange.setBackground("#1a1a2e");
  headerRange.setFontColor("#ffffff");
  headerRange.setFontWeight("bold");
  headerRange.setFontSize(11);
  headerRange.setFontFamily("Arial");
  sheet.setFrozenRows(1);
}
return sheet;
}
// ============================================================
//  TRIGGER MANAGEMENT — 5 MIN AUTO-REFRESH
// ============================================================
function enableAutoRefresh() {
ScriptApp.getProjectTriggers().forEach(t => {
  if (t.getHandlerFunction() === "refreshNewFilings") ScriptApp.deleteTrigger(t);
});
ScriptApp.newTrigger("refreshNewFilings").timeBased().everyMinutes(5).create();
SpreadsheetApp.getUi().alert(
  "✅ Auto-refresh enabled — checking for new filings every 5 minutes.\n\n" +
  "Note: this hits the LDA API repeatedly across 15 companies and their name " +
  "variations every 5 minutes. If you start seeing HTTP errors in the logs, " +
  "you may be getting rate-limited — widen the interval if so."
);
}
function disableAutoRefresh() {
let removed = 0;
ScriptApp.getProjectTriggers().forEach(t => {
  if (t.getHandlerFunction() === "refreshNewFilings") {
    ScriptApp.deleteTrigger(t);
    removed++;
  }
});
SpreadsheetApp.getUi().alert(removed > 0 ? "✅ Auto-refresh disabled." : "No auto-refresh trigger was running.");
}
